{
  "name": "guitar-map",
  "version": "0.0.10",
  "description": "Procedurally generate guitar fretboard diagrams",
  "keywords": [
    "guitar",
    "fretboard",
    "diagrams",
    "music",
    "theory",
    "chords",
    "scales",
    "modes"
  ],
  "homepage": "https://github.com/kwehage/guitar-map#readme",
  "bugs": {
    "url": "https://github.com/kwehage/guitar-map/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kwehage/guitar-map.git"
  },
  "license": "Apache-2.0",
  "author": "Kristopher Wehage",
  "overrides": {
    "extract-zip": "file:./extract-zip-shim"
  },
  "type": "commonjs",
  "main": "main.js",
  "directories": {
    "doc": "doc"
  },
  "scripts": {
    "prebuild": "node prebuild.js",
    "start": "electron-forge start",
    "test": "echo \"Error: no test specified\" && exit 1",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "publish:dry-run": "electron-forge publish --dry-run",
    "publish:from-dry-run": "electron-forge publish --from-dry-run",
    "clean": "rm -rf dist/plotly.min.js out"
  },
  "devDependencies": {
    "adm-zip": "^0.5.16",
    "@electron-forge/cli": "^7.8.3",
    "@electron-forge/maker-dmg": "^7.8.3",
    "@electron-forge/maker-squirrel": "^7.8.3",
    "@electron-forge/maker-zip": "^7.8.3",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.3",
    "@electron-forge/plugin-fuses": "^7.8.3",
    "@electron-forge/publisher-github": "^7.8.3",
    "@electron/fuses": "^1.8.0",
    "@reforged/maker-appimage": "^5.0.0",
    "electron": "37.2.6",
    "playwright-core": "^1.60.0",
    "plotly.js-dist-min": "^2.35.0"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  },
  "build": {
    "asar": false,
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "files": [
      "main.js",
      "dist/**/*"
    ]
  }
}
